/* IALDF Resource Center — shared styles (ialdf.org dark theme) */
:root {
  --bg: #0d1f2b;
  --bg-2: #143246;
  --bg-3: #1a3f5a;
  --ink: #ffffff;
  --ink-2: #c8d0d4;
  --ink-3: #8a9499;
  --peach: #E8A77D;
  --peach-2: #d68f5e;
  --orange: #ea7e3f;
  --orange-hover: #f3914f;
  --gold: #d4a661;
  --warn: #ffd281;
  --crit: #ff8a78;
  --border: rgba(255,255,255,0.08);
  --border-strong: rgba(255,255,255,0.18);
  --card: rgba(255,255,255,0.03);
  --card-hover: rgba(255,255,255,0.06);

  --font-display: "Plus Jakarta Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  --font-body: "Plus Jakarta Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;

  --measure: 68ch;
  --content-max: 1180px;
}

* { box-sizing: border-box; }
html { scroll-behavior: smooth; scroll-padding-top: 96px; }
body {
  margin: 0;
  background: var(--bg);
  color: var(--ink);
  font-family: var(--font-body);
  font-size: 16px;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}
img { max-width: 100%; display: block; }
a { color: var(--peach); text-decoration: none; transition: color .15s; }
a:hover { color: var(--orange); }
hr { border: 0; border-top: 1px solid var(--border); margin: 48px 0; }

h1, h2, h3, h4 {
  font-family: var(--font-display);
  color: var(--ink);
  font-weight: 800;
  letter-spacing: -0.015em;
  margin: 0 0 .4em;
  line-height: 1.1;
  text-wrap: balance;
}
h1 { font-size: clamp(2.2rem, 1.6rem + 2.4vw, 3.6rem); line-height: 1.05; }
h2 { font-size: clamp(1.55rem, 1.25rem + 1vw, 2rem); margin-top: 2em; }
h3 { font-size: 1.2rem; margin-top: 1.6em; color: var(--peach-2); }
h4 { font-size: 1rem; font-weight: 700; margin-top: 1.4em; color: var(--peach); }

p { margin: 0 0 1em; max-width: var(--measure); text-wrap: pretty; }
ul, ol { max-width: var(--measure); padding-left: 1.25em; }
li { margin: .35em 0; }
strong { color: var(--ink); font-weight: 700; }
em { font-style: italic; color: var(--peach); }
sup { color: var(--gold); font-size: 0.7em; font-weight: 700; }

/* ---------- Top bar (slim) ---------- */
.topbar {
  background: #0a1d2a;
  color: var(--ink-3);
  font-size: 12.5px;
  letter-spacing: 0.02em;
  border-bottom: 1px solid var(--border);
}
.topbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 32px;
  max-width: var(--content-max);
  margin: 0 auto;
}
.topbar a { color: var(--ink-2); text-decoration: none; }
.topbar a:hover { color: var(--peach); }
.topbar-meta { display: flex; gap: 16px; }
.topbar-meta span::before { content: "•"; margin-right: 12px; opacity: .4; }
.topbar-meta span:first-child::before { display: none; }

/* ---------- Site header (matches ialdf.org) ---------- */
.site-header {
  background: rgba(12, 26, 32, 0.94);
  backdrop-filter: saturate(140%) blur(8px);
  -webkit-backdrop-filter: saturate(140%) blur(8px);
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  z-index: 100;
}
.nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 32px;
  max-width: var(--content-max);
  margin: 0 auto;
  gap: 32px;
}
.brand {
  display: flex;
  flex-direction: column;
  text-decoration: none;
  line-height: 1;
  gap: 0;
}
.brand-mark { display: none; } /* hide old SVG mark */
.brand-text { display: contents; }
.brand-name {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: 24px;
  color: #fff;
  letter-spacing: 0.02em;
}
.brand-sub {
  font-family: var(--font-display);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.15em;
  color: #fff;
  margin-top: 6px;
  max-width: 130px;
  line-height: 1.3;
}
.nav-links {
  display: flex;
  align-items: center;
  gap: 28px;
  flex-wrap: wrap;
}
.nav-links a {
  color: #fff;
  font-size: 14.5px;
  font-weight: 500;
  text-decoration: none;
  padding: 6px 0;
  border-bottom: 2px solid transparent;
  transition: color .15s, border-color .15s;
}
.nav-links a:hover, .nav-links a.is-current {
  color: var(--peach);
  border-bottom-color: var(--orange);
}
.nav-cta {
  background: var(--orange);
  color: #fff !important;
  padding: 9px 20px !important;
  border-radius: 24px;
  font-weight: 600;
  border: none !important;
  transition: background .15s, transform .15s;
}
.nav-cta:hover { background: var(--orange-hover); transform: translateY(-1px); }
.nav-toggle {
  display: none;
  background: none;
  border: 1px solid var(--border-strong);
  color: #fff;
  padding: 8px 12px;
  border-radius: 4px;
  cursor: pointer;
  font-family: var(--font-display);
  font-size: 13px;
  font-weight: 600;
}
@media (max-width: 940px) {
  .nav-links { display: none; flex-direction: column; align-items: flex-start; width: 100%; padding-top: 16px; gap: 0; }
  .nav-links.is-open { display: flex; }
  .nav-links a { width: 100%; padding: 12px 0; border-bottom: 1px solid var(--border); }
  .nav { flex-wrap: wrap; }
  .nav-toggle { display: inline-block; }
}

/* ---------- Disclaimer band ---------- */
.disclaimer-band {
  background: rgba(234, 126, 63, 0.08);
  border-top: 1px solid rgba(234, 126, 63, 0.25);
  border-bottom: 1px solid rgba(234, 126, 63, 0.25);
  color: var(--peach);
  font-size: 13.5px;
  line-height: 1.5;
}
.disclaimer-band-inner {
  max-width: var(--content-max);
  margin: 0 auto;
  padding: 14px 32px;
  display: flex;
  gap: 14px;
  align-items: flex-start;
}
.disclaimer-band .badge {
  flex-shrink: 0;
  font-family: var(--font-display);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  font-size: 10.5px;
  background: var(--orange);
  color: #fff;
  padding: 4px 9px;
  border-radius: 3px;
  margin-top: 1px;
}
.disclaimer-band p { margin: 0; max-width: none; }

/* ---------- Containers ---------- */
.container { max-width: var(--content-max); margin: 0 auto; padding: 0 32px; }
.container-narrow { max-width: 880px; margin: 0 auto; padding: 0 32px; }

/* ---------- Hero (home) ---------- */
.hero {
  position: relative;
  overflow: hidden;
  background: var(--bg);
  border-bottom: 1px solid var(--border);
}
.hero-pattern, .hero-boteh {
  position: absolute;
  right: -120px;
  bottom: -180px;
  width: 820px;
  height: 820px;
  opacity: 0.22;
  pointer-events: none;
  color: #1a3f5a;
}
.hero-pattern-left {
  position: absolute;
  left: -200px;
  top: -80px;
  width: 560px;
  height: 560px;
  opacity: 0.16;
  pointer-events: none;
  color: #1a3f5a;
}
.hero-inner {
  max-width: var(--content-max);
  margin: 0 auto;
  padding: 88px 32px 96px;
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 64px;
  align-items: center;
  position: relative;
}
@media (max-width: 880px) {
  .hero-inner { grid-template-columns: 1fr; padding: 56px 32px 64px; gap: 32px; }
}
.hero-eyebrow {
  font-size: 12px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--peach);
  font-weight: 700;
  margin-bottom: 22px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.hero-eyebrow::before { content: ""; width: 32px; height: 1.5px; background: var(--orange); }
.hero h1 {
  color: #fff;
  font-size: clamp(2.4rem, 1.6rem + 3vw, 4rem);
  font-weight: 800;
  margin-bottom: 24px;
  letter-spacing: -0.015em;
}
.hero h1 em { font-style: normal; color: var(--peach); }
.hero-lede {
  font-size: 1.05rem;
  color: var(--peach);
  max-width: 38em;
  margin-bottom: 14px;
  line-height: 1.55;
}
.hero-actions {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  margin-top: 28px;
}
.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 22px;
  border-radius: 30px;
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 14.5px;
  text-decoration: none;
  border: 1px solid transparent;
  cursor: pointer;
  transition: background .15s, color .15s, border-color .15s, transform .15s;
}
.btn-primary {
  background: #fff;
  color: var(--bg);
  border-color: #fff;
}
.btn-primary:hover { background: var(--peach); color: var(--bg); transform: translateY(-1px); }
.btn-ghost {
  background: transparent;
  color: #fff;
  border-color: var(--border-strong);
}
.btn-ghost:hover { border-color: var(--peach); color: var(--peach); }
.btn-accent {
  background: var(--orange);
  color: #fff;
  border-color: var(--orange);
}
.btn-accent:hover { background: var(--orange-hover); color: #fff; }

.hero-callout {
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border);
  padding: 28px;
  border-radius: 6px;
  position: relative;
}
.hero-callout-label {
  font-size: 11px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--orange);
  font-weight: 700;
  margin-bottom: 10px;
}
.hero-callout-title {
  font-family: var(--font-display);
  font-size: 1.25rem;
  color: #fff;
  margin: 0 0 12px;
  font-weight: 700;
}
.hero-callout-body {
  font-size: 14px;
  color: var(--ink-2);
  margin: 0 0 18px;
  line-height: 1.55;
}
.hero-callout a {
  color: var(--peach);
  font-size: 14px;
  font-weight: 600;
}
.hero-callout a:hover { color: var(--orange); }

/* ---------- Page header (subpages) ---------- */
.page-header {
  background: var(--bg-2);
  padding: 56px 0 48px;
  border-bottom: 1px solid var(--border);
  position: relative;
  overflow: hidden;
}
.page-header::after {
  content: "";
  position: absolute;
  right: -160px;
  top: 50%;
  transform: translateY(-50%);
  width: 420px;
  height: 420px;
  opacity: 0.08;
  background: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><g fill='none' stroke='%23f4cba0' stroke-width='0.4'><circle cx='50' cy='50' r='40'/><circle cx='50' cy='50' r='30'/><circle cx='50' cy='50' r='20'/><path d='M50 10 L50 90 M10 50 L90 50 M22 22 L78 78 M78 22 L22 78'/></g></svg>") center / contain no-repeat;
  pointer-events: none;
}
.page-header-inner { max-width: var(--content-max); margin: 0 auto; padding: 0 32px; position: relative; }
.page-eyebrow {
  font-size: 12px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--orange);
  font-weight: 700;
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}
.page-eyebrow a { color: var(--orange); text-decoration: none; }
.page-eyebrow a:hover { text-decoration: underline; }
.page-eyebrow .sep { color: var(--ink-3); opacity: .5; }
.page-header h1 { margin-top: 0; max-width: 24ch; color: #fff; }
.page-header .lede { font-size: 1.1rem; color: var(--peach); max-width: 60ch; margin-top: 16px; line-height: 1.55; }
.page-header .updated { font-size: 13px; color: var(--ink-3); margin-top: 18px; letter-spacing: 0.02em; }

/* ---------- Section (home cards section) ---------- */
.section { padding: 80px 0; }
.section-header { max-width: var(--content-max); margin: 0 auto 40px; padding: 0 32px; }
.section-eyebrow {
  font-size: 12px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--orange);
  font-weight: 700;
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.section-title {
  font-size: clamp(1.75rem, 1.4rem + 1.2vw, 2.25rem);
  margin: 0;
  max-width: 24ch;
  color: #fff;
  font-weight: 800;
}
.section-sub {
  font-size: 1.05rem;
  color: var(--peach);
  max-width: 60ch;
  margin-top: 12px;
  line-height: 1.55;
}

/* ---------- Card grid ---------- */
.card-grid {
  max-width: var(--content-max);
  margin: 0 auto;
  padding: 0 32px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}
@media (max-width: 1100px) { .card-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 820px)  { .card-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 520px)  { .card-grid { grid-template-columns: 1fr; } }

.card {
  background: var(--card);
  border: 1px solid var(--border);
  padding: 26px 24px 24px;
  text-decoration: none;
  color: var(--ink);
  display: flex;
  flex-direction: column;
  position: relative;
  transition: background .18s, border-color .18s, transform .18s;
  min-height: 220px;
  border-radius: 6px;
}
.card:hover {
  background: var(--card-hover);
  border-color: var(--orange);
  transform: translateY(-2px);
  color: var(--ink);
}
.card-num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--bg);
  color: #fff;
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 12px;
  margin-bottom: 18px;
  letter-spacing: 0;
}
.card-icon {
  width: 32px; height: 32px;
  color: var(--peach);
  margin-bottom: 16px;
}
.card-title {
  font-family: var(--font-display);
  font-size: 1.15rem;
  font-weight: 700;
  margin: 0 0 8px;
  line-height: 1.2;
  color: #fff;
  letter-spacing: -0.01em;
}
.card-desc {
  font-size: 14px;
  color: var(--ink-2);
  line-height: 1.5;
  margin: 0;
  flex-grow: 1;
}
.card-cta {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 18px;
  font-size: 13.5px;
  color: var(--peach);
  font-weight: 600;
  letter-spacing: 0.01em;
}
.card-cta::after { content: "→"; transition: transform .18s; }
.card:hover .card-cta { color: var(--orange); }
.card:hover .card-cta::after { transform: translateX(3px); }
.card-tag {
  position: absolute;
  top: 14px;
  right: 14px;
  font-size: 9.5px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  background: var(--orange);
  color: #fff;
  padding: 3px 7px;
  font-weight: 700;
  border-radius: 2px;
}

/* ---------- Article body ---------- */
.article {
  background: var(--bg);
  padding: 56px 0 96px;
}
.article-grid {
  max-width: var(--content-max);
  margin: 0 auto;
  padding: 0 32px;
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 64px;
}
@media (max-width: 980px) {
  .article-grid { grid-template-columns: 1fr; gap: 32px; }
  .article-sidebar { order: 2; border-top: 1px solid var(--border); padding-top: 32px; }
}
.article-sidebar {
  position: sticky;
  top: 100px;
  align-self: start;
  font-size: 14px;
}
@media (max-width: 980px) { .article-sidebar { position: static; } }
.article-sidebar-title {
  font-size: 11px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--ink-3);
  margin-bottom: 14px;
  font-weight: 700;
}
.article-sidebar ul { list-style: none; padding: 0; margin: 0; max-width: none; }
.article-sidebar li { margin: 0; border-left: 2px solid var(--border); }
.article-sidebar a {
  display: block;
  padding: 7px 14px;
  color: var(--ink-2);
  text-decoration: none;
  font-size: 14px;
  line-height: 1.4;
  margin-left: -2px;
  border-left: 2px solid transparent;
  transition: color .15s, border-color .15s;
}
.article-sidebar a:hover, .article-sidebar a.is-current {
  color: var(--peach);
  border-left-color: var(--orange);
}

/* ---------- Prose ---------- */
.prose { max-width: 70ch; color: var(--ink-2); }
.prose h2 {
  margin-top: 2em;
  padding-top: .4em;
  border-top: 1px solid var(--border);
  font-size: 1.6rem;
  font-weight: 800;
  color: #fff;
}
.prose h2:first-child { border-top: none; padding-top: 0; margin-top: 0; }
.prose h3 { font-size: 1.15rem; font-weight: 700; color: var(--peach); margin-top: 1.8em; }
.prose h4 { font-size: 1rem; font-weight: 700; color: var(--peach); }
.prose p, .prose ul, .prose ol { font-size: 16px; line-height: 1.65; color: var(--ink-2); }
.prose ul li::marker { color: var(--orange); }
.prose strong { color: var(--ink); font-weight: 700; }
.prose .small { font-size: 13.5px; color: var(--ink-3); }
.prose em { color: var(--peach); font-style: italic; }

/* ---------- Callouts ---------- */
.callout {
  background: var(--card);
  border: 1px solid var(--border);
  border-left: 4px solid var(--gold);
  padding: 20px 22px;
  margin: 28px 0;
  border-radius: 4px;
  max-width: 70ch;
  color: var(--ink-2);
}
.callout-title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.02rem;
  margin: 0 0 8px;
  color: #fff;
  display: flex;
  align-items: center;
  gap: 10px;
}
.callout-title::before {
  content: "";
  width: 16px; height: 16px;
  background: currentColor;
  mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='10'/><line x1='12' y1='8' x2='12' y2='12'/><line x1='12' y1='16' x2='12.01' y2='16'/></svg>") center / contain no-repeat;
  -webkit-mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='10'/><line x1='12' y1='8' x2='12' y2='12'/><line x1='12' y1='16' x2='12.01' y2='16'/></svg>") center / contain no-repeat;
  color: var(--gold);
}
.callout p, .callout ul, .callout ol { color: var(--ink-2); }
.callout p:last-child { margin-bottom: 0; }
.callout-warn { border-left-color: var(--warn); }
.callout-warn .callout-title::before { color: var(--warn); }
.callout-crit { background: rgba(255,138,120,0.06); border-left-color: var(--crit); }
.callout-crit .callout-title::before { color: var(--crit); }
.callout-info { border-left-color: var(--peach); }
.callout-info .callout-title::before { color: var(--peach); }

/* ---------- Phrase rows ---------- */
.phrase-list {
  list-style: none;
  padding: 0;
  margin: 28px 0;
  border-top: 1px solid var(--border);
  max-width: 70ch;
}
.phrase-list li {
  display: grid;
  grid-template-columns: 1fr 1.3fr;
  gap: 24px;
  padding: 18px 0;
  border-bottom: 1px solid var(--border);
  margin: 0;
}
@media (max-width: 640px) { .phrase-list li { grid-template-columns: 1fr; gap: 6px; } }
.phrase-list .situation { font-weight: 600; color: var(--peach); font-size: 14px; }
.phrase-list .what {
  font-family: var(--font-display);
  font-style: italic;
  color: #fff;
  font-size: 16px;
  line-height: 1.45;
}

/* ---------- Tables ---------- */
.table-wrap { overflow-x: auto; margin: 24px 0; max-width: 100%; }
table.kyr {
  width: 100%;
  border-collapse: collapse;
  font-size: 14.5px;
  background: var(--card);
  border: 1px solid var(--border);
  color: var(--ink-2);
}
table.kyr th, table.kyr td {
  padding: 14px 16px;
  text-align: left;
  vertical-align: top;
  border-bottom: 1px solid var(--border);
  border-right: 1px solid var(--border);
  line-height: 1.5;
}
table.kyr th:last-child, table.kyr td:last-child { border-right: none; }
table.kyr tr:last-child td { border-bottom: none; }
table.kyr th {
  background: var(--bg-3);
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--peach);
}
table.kyr td strong { color: #fff; }

/* ---------- Citations ---------- */
.citations {
  margin-top: 48px;
  padding-top: 24px;
  border-top: 1px solid var(--border);
  font-size: 13px;
  color: var(--ink-3);
  max-width: 70ch;
}
.citations h3 {
  font-family: var(--font-display);
  font-size: 11px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--ink-3);
  font-weight: 700;
  margin: 0 0 12px;
}
.citations ol { padding-left: 1.4em; max-width: none; }
.citations li { margin: 6px 0; color: var(--ink-3); }
.citations a, .citations em, .citations strong, .citations sup { color: var(--ink-3); }
.citations a { text-decoration: underline; text-decoration-color: var(--border-strong); }
.citations a:hover { color: var(--peach); text-decoration-color: var(--peach); }

/* ---------- Sub-page nav ---------- */
.subnav {
  background: var(--bg-2);
  border-bottom: 1px solid var(--border);
  font-size: 14px;
  overflow-x: auto;
  position: sticky;
  top: 69px;
  z-index: 50;
}
.subnav-inner {
  max-width: var(--content-max);
  margin: 0 auto;
  padding: 0 32px;
  display: flex;
  gap: 4px;
  white-space: nowrap;
}
.subnav a {
  display: inline-block;
  padding: 14px 16px;
  color: var(--ink-2);
  text-decoration: none;
  border-bottom: 2px solid transparent;
  font-weight: 500;
  letter-spacing: 0.01em;
}
.subnav a:first-child { padding-left: 0; }
.subnav a:hover { color: var(--peach); }
.subnav a.is-current { color: var(--orange); border-bottom-color: var(--orange); }

/* ---------- Related links ---------- */
.related {
  margin-top: 56px;
  padding-top: 36px;
  border-top: 2px solid var(--border);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  max-width: 70ch;
}
@media (max-width: 640px) { .related { grid-template-columns: 1fr; } }
.related a {
  display: block;
  padding: 20px;
  border: 1px solid var(--border);
  background: var(--card);
  text-decoration: none;
  color: var(--ink);
  transition: background .15s, border-color .15s, transform .15s;
  border-radius: 4px;
}
.related a:hover { background: var(--card-hover); border-color: var(--orange); transform: translateY(-1px); color: var(--ink); }
.related-eyebrow { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-3); margin-bottom: 6px; font-weight: 700; }
.related-title { font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: #fff; }

/* ---------- Footer ---------- */
.site-footer {
  background: #0a1d2a;
  color: var(--ink-2);
  padding: 56px 0 28px;
  margin-top: 80px;
  border-top: 1px solid var(--border);
}
.footer-inner {
  max-width: var(--content-max);
  margin: 0 auto;
  padding: 0 32px;
  display: grid;
  grid-template-columns: 1.4fr 1fr 1fr 1fr;
  gap: 40px;
}
@media (max-width: 880px) { .footer-inner { grid-template-columns: 1fr 1fr; } }
@media (max-width: 540px) { .footer-inner { grid-template-columns: 1fr; } }
.footer-inner h4 {
  font-family: var(--font-display);
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--orange);
  font-weight: 700;
  margin: 0 0 14px;
}
.footer-inner ul { list-style: none; padding: 0; margin: 0; max-width: none; }
.footer-inner li { margin: 8px 0; font-size: 14px; }
.footer-inner a { color: var(--ink-2); text-decoration: none; }
.footer-inner a:hover { color: var(--peach); }
.footer-brand { font-family: var(--font-display); font-weight: 900; font-size: 22px; color: #fff; margin-bottom: 6px; letter-spacing: 0.02em; }
.footer-brand-sub { font-size: 10.5px; font-weight: 700; letter-spacing: 0.14em; color: var(--peach); margin-bottom: 18px; }
.footer-tagline { font-size: 14px; color: var(--ink-2); line-height: 1.55; margin-bottom: 14px; max-width: none; }
.footer-bottom {
  max-width: var(--content-max);
  margin: 56px auto 0;
  padding: 22px 32px 0;
  border-top: 1px solid var(--border);
  font-size: 12px;
  color: var(--ink-3);
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px;
}

/* ---------- Templates ---------- */
.template-list { display: grid; gap: 14px; max-width: 880px; margin: 32px 0; }
.template-item {
  display: grid;
  grid-template-columns: 56px 1fr auto;
  gap: 20px;
  align-items: center;
  padding: 20px 22px;
  border: 1px solid var(--border);
  background: var(--card);
  text-decoration: none;
  color: var(--ink);
  transition: background .15s, border-color .15s, transform .15s;
  border-radius: 4px;
}
.template-item:hover { background: var(--card-hover); border-color: var(--orange); transform: translateY(-1px); color: var(--ink); }
.template-icon {
  width: 52px; height: 60px;
  position: relative;
  border-radius: 3px;
  background: linear-gradient(180deg, var(--bg-3), var(--bg-2));
  border: 1px solid var(--border-strong);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 8px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.06em;
  color: var(--peach);
  flex-shrink: 0;
}
.template-icon::before {
  content: "";
  position: absolute;
  top: 0; right: 0;
  width: 14px; height: 14px;
  background: linear-gradient(225deg, transparent, transparent 50%, var(--border-strong) 50%);
}
.template-text .t-title {
  font-family: var(--font-display);
  font-size: 1.05rem;
  font-weight: 700;
  margin-bottom: 4px;
  color: #fff;
}
.template-text .t-desc {
  font-size: 13.5px;
  color: var(--ink-2);
  line-height: 1.5;
}
.template-cta {
  font-size: 13px;
  color: var(--orange);
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 6px;
  letter-spacing: 0.02em;
}

/* ---------- Glossary ---------- */
.glossary { max-width: 880px; margin: 32px 0; }
.glossary-item {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 32px;
  padding: 22px 0;
  border-bottom: 1px solid var(--border);
}
@media (max-width: 640px) { .glossary-item { grid-template-columns: 1fr; gap: 6px; } }
.glossary-term {
  font-family: var(--font-display);
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--peach);
}
.glossary-def { color: var(--ink-2); font-size: 15.5px; line-height: 1.55; }

/* ---------- Status grid ---------- */
.status-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
  margin: 32px 0;
  max-width: 1100px;
}
@media (max-width: 820px) { .status-grid { grid-template-columns: 1fr; } }
.status-card {
  background: var(--card);
  border: 1px solid var(--border);
  padding: 18px 20px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  border-radius: 4px;
}
.status-card:hover { background: var(--card-hover); border-color: var(--orange); }
.status-card .pill {
  display: inline-block;
  width: fit-content;
  font-size: 10.5px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  font-weight: 700;
  padding: 3px 8px;
  border-radius: 2px;
}
.pill-paused { background: rgba(255,138,120,0.15); color: var(--crit); }
.pill-partial { background: rgba(255,210,129,0.15); color: var(--warn); }
.pill-active { background: rgba(244,203,160,0.15); color: var(--peach); }
.status-card .who { font-family: var(--font-display); font-size: 1.02rem; font-weight: 700; color: #fff; }
.status-card .note { font-size: 13px; color: var(--ink-2); margin: 0; line-height: 1.5; }

/* ---------- FAQ accordions ---------- */
.faq-cat { font-family: var(--font-display); font-size: 1.4rem; margin: 48px 0 12px; color: var(--peach); font-weight: 800; }
.faq-item { border-bottom: 1px solid var(--border); padding: 4px 0; }
.faq-item summary {
  list-style: none;
  cursor: pointer;
  padding: 16px 40px 16px 0;
  position: relative;
  font-family: var(--font-display);
  font-size: 1.05rem;
  font-weight: 600;
  color: #fff;
  line-height: 1.4;
}
.faq-item summary::-webkit-details-marker { display: none; }
.faq-item summary::after {
  content: "+";
  position: absolute;
  right: 4px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 26px;
  color: var(--orange);
  font-weight: 300;
  transition: transform .2s;
  font-family: var(--font-display);
}
.faq-item[open] summary::after { content: "–"; }
.faq-item .answer {
  padding: 0 40px 22px 0;
  color: var(--ink-2);
  line-height: 1.65;
  font-size: 15.5px;
}
.faq-item .answer p:last-child { margin-bottom: 0; }
.faq-item .answer ul li::marker { color: var(--orange); }

/* ---------- Misc utilities ---------- */
.eyebrow-mark::before {
  content: "";
  display: inline-block;
  width: 24px;
  height: 1.5px;
  background: var(--orange);
  vertical-align: middle;
  margin-right: 10px;
}
.muted { color: var(--ink-3); }
.peach { color: var(--peach); }
.text-center { text-align: center; }
.term {
  background: rgba(244, 203, 160, 0.1);
  border-bottom: 1px dotted var(--peach);
  padding: 1px 4px;
  cursor: help;
  color: var(--peach);
}

/* Crisis cards (for mental health FAQ entry) */
.crisis-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
  margin: 18px 0;
}
@media (max-width: 760px) { .crisis-grid { grid-template-columns: 1fr; } }
.crisis-card {
  background: var(--card);
  border: 1px solid var(--border);
  padding: 18px 20px;
  border-radius: 4px;
}
.crisis-card .label {
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--orange);
  font-weight: 700;
  margin-bottom: 6px;
}
.crisis-card .name { font-family: var(--font-display); font-size: 1rem; font-weight: 700; margin-bottom: 4px; color: #fff; }
.crisis-card .num { font-family: var(--font-display); font-size: 1.3rem; font-weight: 800; color: var(--peach); margin-bottom: 2px; }
.crisis-card .note { font-size: 12.5px; color: var(--ink-3); margin: 0; }

/* Persian-tile hero pattern (legacy index file) */
.hero-pattern svg, .hero-boteh svg { width: 100%; height: 100%; }

/* ---------- Light section variant (mixed dark/light page) ---------- */
.section-light {
  background: #FFFFFF;
  color: #1a2a33;
  border-top: 1px solid #EBEBEB;
  border-bottom: 1px solid #EBEBEB;
}
.section-light h1,
.section-light h2,
.section-light h3,
.section-light h4 { color: #0d1f2b; }
.section-light .section-eyebrow { color: #c46a3b; }
.section-light .section-eyebrow::before { background: #ea7e3f; }
.section-light .section-eyebrow.eyebrow-mark::before { background: #ea7e3f; }
.section-light .section-title { color: #0d1f2b; }
.section-light .section-sub { color: #c46a3b; }
.section-light p { color: #1a2a33; }
.section-light .card {
  background: #FFFFFF;
  border-color: #EBEBEB;
  color: #0d1f2b;
}
.section-light .card:hover { background: #FFFFFF; border-color: #ea7e3f; }
.section-light .card-title { color: #0d1f2b; }
.section-light .card-desc { color: #c46a3b; }
.section-light .card-cta { color: #ea7e3f; }
.section-light .card:hover .card-cta { color: #c46228; }
.section-light .card-icon { color: #134752; }
.section-light .card-num { background: #0d1f2b; color: #ffffff; }
.section-light .card-tag { background: #ea7e3f; color: #fff; }
.section-light .callout {
  background: #ffffff;
  border-color: #EBEBEB;
  color: #1a2a33;
}
.section-light .callout-title { color: #0d1f2b; }
.section-light .callout p, .section-light .callout ul, .section-light .callout ol { color: #1a2a33; }
.section-light .callout strong { color: #0d1f2b; }
.section-light .prose { color: #1a2a33; }
.section-light .prose h2, .section-light .prose h3, .section-light .prose h4 { color: #0d1f2b; }
.section-light .prose h3 { color: #134752; }
.section-light .prose strong { color: #0d1f2b; }
.section-light .prose em { color: #c46a3b; }
.section-light a { color: #c46228; }
.section-light a:hover { color: #ea7e3f; }
.section-light .btn-accent { background: #ea7e3f; color: #fff; }
.section-light .btn-accent:hover { background: #c46228; }
.section-light .btn-ghost {
  background: transparent;
  color: #0d1f2b;
  border-color: #EBEBEB;
}
.section-light .btn-ghost:hover { border-color: #ea7e3f; color: #ea7e3f; }

/* section-light card shadow */
.section-light .card,
.section-light .jump-card,
.section-light .callout,
.section-light .template-item,
.section-light .status-card,
.section-light .crisis-card {
  box-shadow: 0 1px 2px rgba(13,31,43,0.05), 0 8px 24px -12px rgba(13,31,43,0.15);
  border-radius: 8px;
}
.section-light .card { padding: 30px 28px 26px; min-height: 260px; }
.section-light .card-num { width: 32px; height: 32px; font-size: 13px; margin-bottom: 22px; }
.section-light .card-title { font-size: 1.2rem; margin-bottom: 10px; }
.section-light .card-desc { line-height: 1.55; }
.section-light .card-cta { margin-top: 20px; font-size: 14px; font-weight: 600; }
.section-light .card:hover,
.section-light .jump-card:hover,
.section-light .template-item:hover {
  box-shadow: 0 2px 4px rgba(13,31,43,0.06), 0 14px 32px -10px rgba(13,31,43,0.22);
  transform: translateY(-3px);
}


/* ---------- Collapsible citations ---------- */
details.citations {
  margin-top: 40px;
  padding: 14px 0 0;
  border-top: 1px solid var(--border);
  font-size: 12.5px;
}
details.citations summary {
  list-style: none;
  cursor: pointer;
  font-size: 11px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--ink-3);
  font-weight: 700;
  padding: 8px 24px 8px 0;
  position: relative;
  display: inline-block;
}
details.citations summary::-webkit-details-marker { display: none; }
details.citations summary::after {
  content: "+";
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  font-size: 16px;
  color: var(--orange);
  font-weight: 300;
  transition: transform .15s;
}
details.citations[open] summary::after { content: "–"; }
details.citations summary:hover { color: var(--peach); }
details.citations ol { padding-left: 1.4em; max-width: none; margin-top: 8px; }
details.citations li { margin: 4px 0; color: var(--ink-3); }
details.citations a, details.citations em, details.citations strong, details.citations sup { color: var(--ink-3); }
details.citations a { text-decoration: underline; text-decoration-color: var(--border-strong); }
details.citations a:hover { color: var(--peach); text-decoration-color: var(--peach); }

/* Light-section variant */
.section-light details.citations { border-top-color: #EBEBEB; color: #6f7d8e; }
.section-light details.citations summary { color: #6f7d8e; }
.section-light details.citations summary::after { color: #ea7e3f; }
.section-light details.citations summary:hover { color: #c46228; }
.section-light details.citations li, .section-light details.citations a, .section-light details.citations em, .section-light details.citations strong, .section-light details.citations sup { color: #6f7d8e; }
.section-light details.citations a:hover { color: #c46228; }


/* ---------- Back-to-top floating button ---------- */
.back-to-top {
  position: fixed;
  right: 24px;
  bottom: 24px;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: #ea7e3f;
  color: #fff;
  border: none;
  cursor: pointer;
  font-size: 20px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 14px rgba(0,0,0,0.35);
  z-index: 90;
  opacity: 0;
  visibility: hidden;
  transition: opacity .2s, visibility .2s, transform .15s, background .15s;
  font-family: inherit;
  line-height: 1;
}
.back-to-top.is-visible { opacity: 1; visibility: visible; }
.back-to-top:hover { background: #f3914f; transform: translateY(-2px); }
.back-to-top:focus-visible { outline: 2px solid #fff; outline-offset: 2px; }
